# Copy this file to .env only for local development.
# Never commit the real .env file.

# HTTP port exposed by the Socket.IO service.
PORT=4000

# URL that the Node service uses to call the Spring Boot backend.
# In Docker Compose this is usually http://verdenote-core:8080.
VERDENOTE_CORE_URL=http://localhost:8080

# Comma-separated frontend origins allowed to connect to Socket.IO.
# Production example: https://app.example.com
VERDENOTE_NODE_CORS_ORIGIN=https://verdenote.sobrinholabs.tech

# Shared secret used only between verdenote-node and verdenote-core.
# The value must be exactly the same in both services.
VERDENOTE_REALTIME_SERVICE_SECRET=change-me-in-production
